<?xml version="1.0" encoding="UTF-8"?>
<AiEvaluationDefinition xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>PlanForLater</name>
    <subjectName>MyOrgButler</subjectName>
    <subjectType>AGENT</subjectType>
    <subjectVersion>v1</subjectVersion>
    <description>Schedules future work via PlanForLater</description>
    <testCase>
        <number>1</number>
        <inputs><utterance>every weekday at 9am, check for opportunities closing this week and notify me</utterance></inputs>
        <expectation><name>topic_assertion</name><expectedValue>MyOrgButler</expectedValue></expectation>
        <expectation><name>actions_assertion</name><expectedValue>['PlanForLater']</expectedValue></expectation>
        <expectation><name>bot_response_rating</name><expectedValue>Confirms the plan was scheduled successfully and provides a link to the plan record</expectedValue></expectation>
    </testCase>
</AiEvaluationDefinition>
