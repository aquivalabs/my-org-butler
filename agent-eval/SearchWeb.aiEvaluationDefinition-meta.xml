<?xml version="1.0" encoding="UTF-8"?>
<AiEvaluationDefinition xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>SearchWeb</name>
    <subjectName>MyOrgButler</subjectName>
    <subjectType>AGENT</subjectType>
    <subjectVersion>v1</subjectVersion>
    <description>Answers outside-org questions via SearchWeb</description>
    <testCase>
        <number>1</number>
        <inputs><utterance>where is Aquiva Labs located and when were they founded? search the web</utterance></inputs>
        <expectation><name>topic_assertion</name><expectedValue>MyOrgButler</expectedValue></expectation>
        <expectation><name>actions_assertion</name><expectedValue>['SearchWeb']</expectedValue></expectation>
        <expectation><name>bot_response_rating</name><expectedValue>Mentions Florida (Celebration or Orlando) as location and 2015 as founding year</expectedValue></expectation>
    </testCase>
</AiEvaluationDefinition>
